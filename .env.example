# PsycHeal Server Configuration
PORT=3000

# 1. Core LLM Configuration (accessed server-side only)
GEMINI_API_KEY=
AI_PROVIDER=gemini # Toggle to 'open_weight_model' to use self-hosted models

# Optional: Only required if AI_PROVIDER is set to 'open_weight_model'
OPEN_WEIGHT_MODEL_API_URL=https://api.openai.com/v1
OPEN_WEIGHT_MODEL_API_KEY=
OPEN_WEIGHT_MODEL_NAME=gemma2-9b-it

# 2. Voice Synthesis Configuration (accessed server-side only)
ELEVENLABS_API_KEY=

# 3. Database Configurations
DATABASE_URL=

# 4. Supabase Configurations (Client-side)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

